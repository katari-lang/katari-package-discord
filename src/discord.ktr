// The Discord library: a gateway-client capability plus the watch / send agents, the Discord twin
// of the Slack package. The externals are implemented in `discord.ts` (the same module path, so they
// register under `discord.*`). The one-line integration is the provider:
// `use discord.provider(source = credentials.env(key = "DISCORD_TOKEN"))`.
//
// Files are first-class on both directions: an incoming message's attachments arrive as `file`
// values (the sidecar downloads each and uploads it over the blob side channel), and `send_message`
// posts `file` values back as Discord attachments.

@"The live Discord gateway connection (the JS client lives in the sidecar; the handle is opaque)."
request connection() -> string

@"Provide the Discord gateway connection for the extent of the continuation: resolve @source@ ONCE
(a gateway credential is fixed at connect — the websocket's nature, so a rotation lands on the next
restart, not mid-connection), log in, then serve `connection` to everything downstream. A failed
login (a bad token, a transient network fault) raises `discord_error` (`auth_error` | `api_error`) —
surfacing here rather than on the first send."
agent provider[R, effect E](
  @"Where the bot token lives (env key or oauth name); resolved once at connect." source: credentials.source,
  @"Runs with `connection` served; its result is the provider's result." continuation: agent (value: null) -> R with {...E, connection},
) -> R with E | io | prelude.throw[discord_error | env.missing_secret | oauth.server_error] {
  let client = create_discord_client(token = credentials.resolve(source = source))
  // Bind the gateway connection's lifetime to this run: however the provider ends — normal completion,
  // cancel, or the continuation unwinding — destroy the client on the way out, so a dead run does not
  // leave a logged-in gateway session still receiving and handling events.
  finally { discord_close(client = client) }
  use handler {
    request connection() { next client }
  }
  continuation(value = null)
}

@"Connect to Discord and log in; returns an opaque client handle. Raises `discord_error` (`auth_error`
| `api_error`) when the login fails — an invalid token / missing permission is `auth_error`, a transient
network fault `api_error`. Prefer the provider."
external agent create_discord_client(
  @"The bot token to log in with." token: string of private,
) -> string with prelude.throw[discord_error]

@"Close a Discord connection: destroy the gateway client and drop the handle. The provider arms this
as a `finally`, so the connection dies with the run — a gateway client left alive stays logged in and
keeps receiving events long after its run is gone, a leaked session that still handles messages.
Idempotent: closing an unknown or already-closed handle is a no-op, since a finalizer may run more
than once."
external agent discord_close(
  @"The opaque client handle `create_discord_client` returned." client: string,
) -> null

@"An authentication / authorization failure: the bot token is invalid or expired (HTTP 401), or the
bot lacks permission in the channel (HTTP 403); @message@ carries Discord's error. The bot cannot
recover on its own — the operator must fix the token or the bot's permissions and restart the run (the
connection is fixed at start). Let it surface so the bot stops loudly rather than silently dropping
every reply."
data auth_error(message: string)

@"A Discord API call failed for a non-auth reason: a rate limit (HTTP 429), a channel that is not a
sendable text channel, a transient network fault; @message@ carries Discord's error. Usually
per-message or transient, so a bot catches it to drop just that reply and keep serving."
data api_error(message: string)

// A Discord send failure: an auth/authorization failure or a plain API failure. Raised as a
// `prelude.throw` (never a panic — that would tear the whole run down), classified in the sidecar by
// the HTTP status. (Type synonyms take no docs.)
type discord_error = auth_error | api_error

@"Low-level: post to a channel on a given client, with any files as attachments. Raises `auth_error`
or `api_error` (`discord_error`) when the Discord API call fails. Prefer the send_message agent."
external agent discord_send(
  @"The opaque client handle to post through." client: string,
  @"The channel to post into." channel: string,
  @"The message text; empty means an attachments-only post." text: string,
  @"Files to attach to the post." files: array[file],
) -> null with prelude.throw[discord_error]

@"Low-level: listen on a channel and deliver each incoming message (channel / text / attachments
as files) to a callback. Prefer the watch_messages agent."
external agent discord_watch[effect E](
  @"The opaque client handle to listen through." client: string,
  @"The channel to listen on." channel: string,
  @"Called once per incoming message; its effects E flow to the caller's handlers." deliver_to: agent (channel: string, text: string, files: array[file]) -> null with E,
) -> never with E

@"Post a message to a channel using the ambient Discord client; @files@ attach to it (pass `[]`
for a plain text post — parameter defaults only take literals, so the empty array cannot default).
Raises `discord_error` (`auth_error` | `api_error`) when the send fails — catch `api_error` to keep a
bot serving past a transient failure, and let `auth_error` surface so a bad token stops the bot loudly."
agent send_message(
  @"The channel to post into." channel: string,
  @"The message text; empty means an attachments-only post." text: string,
  @"Files to attach; pass `[]` for a plain text post." files: array[file],
) -> null {
  discord_send(client = connection(), channel = channel, text = text, files = files)
}

@"Tool: post files (images) to a Discord channel, with a caption. Use the channel id given in the
conversation context; pass each file as its handle object — a bare {\"$katari_ref\": \"<id>\"} suffices."
agent send_files(
  @"The channel to post into (given in the conversation context)." channel: string,
  @"The files to post; pass each as its handle object — a bare {\"$katari_ref\": \"<id>\"} suffices." files: array[file],
  @"The text posted alongside the files." caption: string,
) -> null {
  send_message(channel = channel, text = caption, files = files)
}

@"Serve a channel forever, delivering each incoming message to @deliver_to@ — shaped like
`time.watch` / `google_calendar.watch` so it composes under `parallel [ … ]`. Bot posts (this bot's
own replies included) are not delivered, so replying from @deliver_to@ cannot loop."
agent watch_messages[effect E](
  @"The channel to serve." channel: string,
  @"Called once per incoming message; its effects E flow to the caller's handlers." deliver_to: agent (channel: string, text: string, files: array[file]) -> null with E,
) -> never with E | connection | io {
  discord_watch(client = connection(), channel = channel, deliver_to = deliver_to)
}
